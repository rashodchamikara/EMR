generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum OrganizationType {
  CLINIC
  HOSPITAL
  LABORATORY
  PHARMACY
  DIAGNOSTIC_CENTER
  OTHER
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Organization {
  id            String             @id @default(uuid()) @db.Char(36)
  code          String             @unique @db.VarChar(30)
  name          String             @db.VarChar(150)
  legalName     String?            @map("legal_name") @db.VarChar(200)
  type          OrganizationType   @default(CLINIC)
  status        OrganizationStatus @default(ACTIVE)
  timezone      String             @default("Asia/Colombo") @db.VarChar(50)
  locale        String             @default("en-LK") @db.VarChar(20)
  phone         String?            @db.VarChar(30)
  email         String?            @db.VarChar(254)
  addressLine1  String?            @map("address_line_1") @db.VarChar(200)
  addressLine2  String?            @map("address_line_2") @db.VarChar(200)
  city          String?            @db.VarChar(100)
  stateProvince String?            @map("state_province") @db.VarChar(100)
  postalCode    String?            @map("postal_code") @db.VarChar(20)
  countryCode   String             @default("LK") @map("country_code") @db.Char(2)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([name])
  @@index([status])
  @@index([type])
  @@map("organizations")
}
