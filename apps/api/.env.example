NODE_ENV=development 

APP_NAME=EMR API
APP_VERSION=0.1.0
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=debug
DATABASE_URL=mysql://emr_user:change_me@127.0.0.1:3307/emr_dev
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=emr_dev
DB_USER=emr_user
DB_PASSWORD=change_me
DB_CONNECTION_LIMIT=10

SHADOW_DATABASE_URL=mysql://emr_user:change_me@127.0.0.1:3307/emr_shadow

JWT_ACCESS_SECRET=generate_a_long_random_value
JWT_ISSUER=emr-api
JWT_AUDIENCE=emr-web
ACCESS_TOKEN_TTL_SECONDS=300
SESSION_TTL_DAYS=30
REFRESH_COOKIE_NAME=emr_refresh
COOKIE_SECURE=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
SEED_ADMIN_EMAIL=admin@emr.local
SEED_ADMIN_PASSWORD=change_me
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator